<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Wellness Test</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <link rel="manifest" href="manifest.webmanifest">
  <link rel="apple-touch-icon" href="icon.png">
  <style>
    :root {
      --bg: #0f172a;
      --card: #111827;
      --accent: #38bdf8;
      --text: #e5e7eb;
      --muted: #9ca3af;
      --danger: #f97373;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: -apple-system, system-ui, sans-serif;
      background: radial-gradient(circle at top, #1f2937 0, #020617 55%);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: stretch;
    }
    .app {
      width: 100%;
      max-width: 480px;
      padding: 16px;
    }
    .card {
      background: linear-gradient(145deg, #020617, #111827);
      border-radius: 18px;
      padding: 16px 18px 20px;
      box-shadow: 0 18px 40px rgba(0,0,0,0.6);
      border: 1px solid rgba(148,163,184,0.25);
    }
    h1 {
      font-size: 24px;
      margin: 0 0 4px;
      letter-spacing: 0.03em;
    }
    .subtitle {
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 12px;
    }
    .mode-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px 10px;
      border-radius: 999px;
      background: rgba(15,23,42,0.9);
      border: 1px solid rgba(148,163,184,0.4);
      font-size: 11px;
      color: var(--muted);
      margin-bottom: 10px;
    }
    .mode-pill span.mode {
      color: var(--accent);
      font-weight: 600;
    }
    .segmented {
      display: inline-flex;
      border-radius: 999px;
      background: rgba(15,23,42,0.9);
      border: 1px solid rgba(148,163,184,0.4);
      overflow: hidden;
      margin-bottom: 12px;
    }
    .segmented button {
      border: none;
      background: transparent;
      color: var(--muted);
      padding: 4px 10px;
      font-size: 12px;
    }
    .segmented button.active {
      background: rgba(56,189,248,0.15);
      color: var(--accent);
      font-weight: 600;
    }
    .section-title {
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--muted);
      margin: 10px 0 4px;
    }
    .words {
      display: flex;
      gap: 8px;
      margin: 8px 0 10px;
      flex-wrap: wrap;
    }
    .word-chip {
      padding: 6px 10px;
      border-radius: 999px;
      background: rgba(15,23,42,0.9);
      border: 1px solid rgba(148,163,184,0.4);
      font-size: 13px;
      letter-spacing: 0.06em;
    }
    .hint {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 10px;
    }
    .row {
      display: flex;
      gap: 8px;
      margin-top: 8px;
      flex-wrap: wrap;
    }
    button.primary, button.secondary, button.ghost {
      border-radius: 999px;
      border: none;
      padding: 8px 14px;
      font-size: 14px;
      font-weight: 500;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    button.primary {
      background: var(--accent);
      color: #020617;
    }
    button.secondary {
      background: rgba(15,23,42,0.9);
      color: var(--text);
      border: 1px solid rgba(148,163,184,0.5);
    }
    button.ghost {
      background: transparent;
      color: var(--muted);
    }
    button:active {
      transform: scale(0.97);
    }
    input[type="text"], input[type="number"] {
      width: 100%;
      padding: 8px 10px;
      border-radius: 10px;
      border: 1px solid rgba(148,163,184,0.5);
      background: rgba(15,23,42,0.9);
      color: var(--text);
      font-size: 14px;
    }
    input::placeholder {
      color: rgba(148,163,184,0.7);
    }
    .timer {
      font-size: 28px;
      font-variant-numeric: tabular-nums;
      margin: 6px 0 10px;
    }
    .tabs {
      display: flex;
      gap: 6px;
      margin-top: 12px;
      margin-bottom: 8px;
    }
    .tab {
      flex: 1;
      text-align: center;
      padding: 6px 0;
      border-radius: 999px;
      font-size: 13px;
      border: 1px solid rgba(148,163,184,0.4);
      color: var(--muted);
    }
    .tab.active {
      background: rgba(56,189,248,0.15);
      border-color: var(--accent);
      color: var(--accent);
      font-weight: 600;
    }
    canvas {
      background: radial-gradient(circle at top, #020617 0, #020617 40%, #020617 100%);
      border-radius: 999px;
      border: 1px solid rgba(148,163,184,0.4);
      touch-action: manipulation;
    }
    .history {
      margin-top: 10px;
      max-height: 140px;
      overflow-y: auto;
      font-size: 12px;
      border-radius: 10px;
      background: rgba(15,23,42,0.8);
      border: 1px solid rgba(148,163,184,0.4);
      padding: 8px;
    }
    .history-entry {
      margin-bottom: 4px;
      color: var(--muted);
    }
    .badge {
      display: inline-block;
      padding: 2px 6px;
      border-radius: 999px;
      font-size: 11px;
      background: rgba(56,189,248,0.15);
      color: var(--accent);
      margin-left: 4px;
    }
  </style>
</head>
<body>
  <div class="app">
    <div class="card">
      <h1>Wellness Test</h1>
      <div class="subtitle">3‑word recall + clock, right on your Home Screen.</div>

      <div class="mode-pill">
        Mode:
        <span class="mode" id="modeLabel">Practice</span>
      </div>
      <div class="segmented">
        <button id="practiceBtn" class="active">Practice</button>
        <button id="clinicianBtn">Clinician</button>
      </div>

      <div class="section-title">3‑Word Memory</div>
      <div class="words" id="wordList"></div>
      <div class="hint" id="phaseHint"></div>

      <div id="recallInputs" style="display:none; margin-top:6px;">
        <input type="text" id="recall1" placeholder="Word 1" />
        <input type="text" id="recall2" placeholder="Word 2" style="margin-top:6px;" />
        <input type="text" id="recall3" placeholder="Word 3" style="margin-top:6px;" />
      </div>

      <div id="timerBlock" style="display:none;">
        <div class="timer" id="timerDisplay">5</div>
        <div class="hint">Count backward from 100 by 7 in your head.</div>
      </div>

      <div id="scoreBlock" style="display:none; margin-top:8px;">
        <div class="hint">
          Score:
          <span id="scoreText"></span>
        </div>
      </div>

      <div class="row">
        <button class="primary" id="startBtn">Start New Test</button>
        <button class="secondary" id="speakBtn">Speak Words</button>
      </div>

      <div class="row">
        <button class="secondary" id="phaseBtn">Next Phase</button>
        <button class="ghost" id="clearBtn">Clear Inputs</button>
      </div>

      <div class="section-title">Clock Test</div>
      <div class="hint">Tap once for hour hand, again for minute hand (target: 11:10).</div>
      <div style="margin-top:6px; display:flex; justify-content:center;">
        <canvas id="clockCanvas" width="260" height="260"></canvas>
      </div>
      <div class="hint" id="clockInfo"></div>

      <div class="row">
        <button class="secondary" id="resetClockBtn">Reset Clock</button>
      </div>

      <div class="section-title">
        Settings & History
      </div>
      <div class="hint">
        Distractor (seconds):
      </div>
      <input type="number" id="distractorInput" min="3" max="60" value="5" />

      <div class="row" style="margin-top:8px;">
        <button class="secondary" id="saveSettingsBtn">Save Settings</button>
        <button class="ghost" id="exportTextBtn">Copy Summary</button>
      </div>

      <div class="history" id="historyBox"></div>
    </div>
  </div>

  <script>
    // ---------- Data & State ----------
    const wordLists = {
      miniCog: ["APPLE", "PENNY", "TABLE"],
      moca: ["FACE", "VELVET", "CHURCH", "DAISY", "RED"],
      slums: ["APPLE", "PENNY", "TABLE"]
    };

    let mode = localStorage.getItem("wt_mode") || "practice";
    let phase = "show"; // show -> distractor -> recall -> scored
    let targetWords = [];
    let distractorSeconds = parseInt(localStorage.getItem("wt_distractor") || "5", 10);
    let timer = null;
    let remaining = distractorSeconds;

    let clockHourAngle = 0;
    let clockMinuteAngle = 0;
    let clockHourSet = false;

    // ---------- Elements ----------
    const modeLabel = document.getElementById("modeLabel");
    const practiceBtn = document.getElementById("practiceBtn");
    const clinicianBtn = document.getElementById("clinicianBtn");

    const wordListEl = document.getElementById("wordList");
    const phaseHint = document.getElementById("phaseHint");
    const recallInputs = document.getElementById("recallInputs");
    const recall1 = document.getElementById("recall1");
    const recall2 = document.getElementById("recall2");
    const recall3 = document.getElementById("recall3");

    const timerBlock = document.getElementById("timerBlock");
    const timerDisplay = document.getElementById("timerDisplay");
    const scoreBlock = document.getElementById("scoreBlock");
    const scoreText = document.getElementById("scoreText");

    const startBtn = document.getElementById("startBtn");
    const speakBtn = document.getElementById("speakBtn");
    const phaseBtn = document.getElementById("phaseBtn");
    const clearBtn = document.getElementById("clearBtn");

    const clockCanvas = document.getElementById("clockCanvas");
    const clockInfo = document.getElementById("clockInfo");
    const resetClockBtn = document.getElementById("resetClockBtn");

    const distractorInput = document.getElementById("distractorInput");
    const saveSettingsBtn = document.getElementById("saveSettingsBtn");
    const exportTextBtn = document.getElementById("exportTextBtn");
    const historyBox = document.getElementById("historyBox");

    // ---------- Mode ----------
    function updateModeUI() {
      modeLabel.textContent = mode === "clinician" ? "Clinician" : "Practice";
      practiceBtn.classList.toggle("active", mode === "practice");
      clinicianBtn.classList.toggle("active", mode === "clinician");
    }

    practiceBtn.onclick = () => {
      mode = "practice";
      localStorage.setItem("wt_mode", mode);
      updateModeUI();
    };
    clinicianBtn.onclick = () => {
      mode = "clinician";
      localStorage.setItem("wt_mode", mode);
      updateModeUI();
    };

    // ---------- Word Logic ----------
    function pickWords() {
      const lists = [
        wordLists.miniCog,
        shuffle([...wordLists.moca]).slice(0, 3),
        wordLists.slums
      ];
      targetWords = shuffle(lists[Math.floor(Math.random() * lists.length)]);
    }

    function renderWords() {
      wordListEl.innerHTML = "";
      targetWords.forEach(w => {
        const span = document.createElement("span");
        span.className = "word-chip";
        span.textContent = w;
        wordListEl.appendChild(span);
      });
    }

    function startTest() {
      clearInterval(timer);
      pickWords();
      renderWords();
      recall1.value = "";
      recall2.value = "";
      recall3.value = "";
      scoreBlock.style.display = "none";
      recallInputs.style.display = "none";
      timerBlock.style.display = "none";
      phase = "show";
      phaseHint.textContent = "Study these three words. When ready, move to the distractor.";
      remaining = distractorSeconds;
      timerDisplay.textContent = remaining;
    }

    function startDistractor() {
      phase = "distractor";
      recallInputs.style.display = "none";
      timerBlock.style.display = "block";
      phaseHint.textContent = "Count backward from 100 by 7 in your head.";
      remaining = distractorSeconds;
      timerDisplay.textContent = remaining;
      clearInterval(timer);
      timer = setInterval(() => {
        remaining--;
        timerDisplay.textContent = remaining;
        if (remaining <= 0) {
          clearInterval(timer);
          startRecall();
        }
      }, 1000);
    }

    function startRecall() {
      phase = "recall";
      timerBlock.style.display = "none";
      recallInputs.style.display = "block";
      phaseHint.textContent = "Type the three words you remember.";
    }

    function scoreRecall() {
      phase = "scored";
      const inputs = [recall1.value, recall2.value, recall3.value]
        .map(s => s.trim().toUpperCase())
        .filter(Boolean);
      const targets = targetWords.map(w => w.toUpperCase());
      let score = 0;
      inputs.forEach(i => {
        if (targets.includes(i)) score++;
      });
      scoreText.textContent = `${score} / 3`;
      scoreBlock.style.display = "block";
      phaseHint.textContent = "Result recorded. You can review history below.";

      if (mode === "clinician") {
        appendHistory(score);
      }
    }

    // ---------- History ----------
    function appendHistory(score) {
      const entry = {
        ts: new Date().toISOString(),
        score,
        words: targetWords,
        mode,
        clock: {
          hourAngle: clockHourAngle,
          minuteAngle: clockMinuteAngle
        }
      };
      const existing = JSON.parse(localStorage.getItem("wt_history") || "[]");
      existing.unshift(entry);
      localStorage.setItem("wt_history", JSON.stringify(existing));
      renderHistory();
    }

    function renderHistory() {
      const existing = JSON.parse(localStorage.getItem("wt_history") || "[]");
      historyBox.innerHTML = "";
      if (!existing.length) {
        historyBox.innerHTML = '<div class="history-entry">No history yet.</div>';
        return;
      }
      existing.slice(0, 20).forEach(e => {
        const div = document.createElement("div");
        div.className = "history-entry";
        const date = new Date(e.ts).toLocaleString();
        div.textContent = `${date} — ${e.score}/3 — [${e.words.join(", ")}]`;
        historyBox.appendChild(div);
      });
    }

    // ---------- Clock ----------
    function drawClock() {
      const ctx = clockCanvas.getContext("2d");
      const w = clockCanvas.width;
      const h = clockCanvas.height;
      const cx = w / 2;
      const cy = h / 2;
      const r = Math.min(w, h) / 2 - 12;

      ctx.clearRect(0, 0, w, h);

      // face
      ctx.beginPath();
      ctx.arc(cx, cy, r, 0, Math.PI * 2);
      ctx.fillStyle = "#020617";
      ctx.fill();
      ctx.strokeStyle = "rgba(148,163,184,0.7)";
      ctx.lineWidth = 2;
      ctx.stroke();

      // ticks
      for (let i = 0; i < 12; i++) {
        const angle = (i / 12) * Math.PI * 2;
        const x1 = cx + Math.sin(angle) * (r - 10);
        const y1 = cy - Math.cos(angle) * (r - 10);
        const x2 = cx + Math.sin(angle) * (r - 2);
        const y2 = cy - Math.cos(angle) * (r - 2);
        ctx.beginPath();
        ctx.moveTo(x1, y1);
        ctx.lineTo(x2, y2);
        ctx.strokeStyle = "rgba(148,163,184,0.7)";
        ctx.lineWidth = 2;
        ctx.stroke();
      }

      // hour hand
      ctx.save();
      ctx.translate(cx, cy);
      ctx.rotate((clockHourAngle * Math.PI) / 180);
      ctx.beginPath();
      ctx.moveTo(0, 8);
      ctx.lineTo(0, -r * 0.5);
      ctx.strokeStyle = "#e5e7eb";
      ctx.lineWidth = 4;
      ctx.lineCap = "round";
      ctx.stroke();
      ctx.restore();

      // minute hand
      ctx.save();
      ctx.translate(cx, cy);
      ctx.rotate((clockMinuteAngle * Math.PI) / 180);
      ctx.beginPath();
      ctx.moveTo(0, 10);
      ctx.lineTo(0, -r * 0.75);
      ctx.strokeStyle = "#38bdf8";
      ctx.lineWidth = 3;
      ctx.lineCap = "round";
      ctx.stroke();
      ctx.restore();

      // center
      ctx.beginPath();
      ctx.arc(cx, cy, 4, 0, Math.PI * 2);
      ctx.fillStyle = "#38bdf8";
      ctx.fill();

      clockInfo.textContent =
        `Hour: ${clockHourAngle.toFixed(0)}°, Minute: ${clockMinuteAngle.toFixed(0)}° (target ≈ 330° & 60°)`;
    }

    function resetClock() {
      clockHourAngle = 0;
      clockMinuteAngle = 0;
      clockHourSet = false;
      drawClock();
    }

    clockCanvas.addEventListener("click", (e) => {
      const rect = clockCanvas.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const cx = clockCanvas.width / 2;
      const cy = clockCanvas.height / 2;
      const dx = x - cx;
      const dy = cy - y;
      const angleDeg = (Math.atan2(dx, dy) * 180) / Math.PI;

      if (!clockHourSet) {
        clockHourAngle = angleDeg;
        clockHourSet = true;
      } else {
        clockMinuteAngle = angleDeg;
      }
      drawClock();
    });

    resetClockBtn.onclick = resetClock;

    // ---------- Speech ----------
    function speakWords() {
      if (!("speechSynthesis" in window)) {
        alert("Speech not supported in this browser.");
        return;
      }
      const utter = new SpeechSynthesisUtterance(targetWords.join(", "));
      utter.rate = 0.8;
      utter.pitch = 1.0;
      utter.lang = "en-US";
      window.speechSynthesis.cancel();
      window.speechSynthesis.speak(utter);
    }

    // ---------- Settings ----------
    distractorInput.value = distractorSeconds;
    function saveSettings() {
      const v = parseInt(distractorInput.value || "5", 10);
      distractorSeconds = Math.max(3, Math.min(60, v));
      localStorage.setItem("wt_distractor", distractorSeconds.toString());
      remaining = distractorSeconds;
      timerDisplay.textContent = remaining;
    }

    // ---------- Export (text copy) ----------
    function exportSummary() {
      const history = JSON.parse(localStorage.getItem("wt_history") || "[]");
      if (!history.length) {
        alert("No history to export yet.");
        return;
      }
      const lines = history.map(e => {
        return `${e.ts} | mode=${e.mode} | score=${e.score}/3 | words=[${e.words.join(", ")}] | clock=(H:${e.clock.hourAngle.toFixed(0)}°, M:${e.clock.minuteAngle.toFixed(0)}°)`;
      });
      const text = lines.join("\n");
      navigator.clipboard.writeText(text).then(() => {
        alert("Summary copied. Paste into Notes or a document to save/share.");
      }).catch(() => {
        alert("Could not copy automatically. You may need to allow clipboard access.");
      });
    }

    // ---------- Phase Button ----------
    function handlePhase() {
      if (phase === "show") {
        if (mode === "practice") {
          startRecall();
        } else {
          startDistractor();
        }
      } else if (phase === "distractor") {
        startRecall();
      } else if (phase === "recall") {
        scoreRecall();
      } else if (phase === "scored") {
        startTest();
      }
    }

    // ---------- Utils ----------
    function shuffle(arr) {
      for (let i = arr.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [arr[i], arr[j]] = [arr[j], arr[i]];
      }
      return arr;
    }

    // ---------- Wire up ----------
    startBtn.onclick = startTest;
    speakBtn.onclick = speakWords;
    phaseBtn.onclick = handlePhase;
    clearBtn.onclick = () => {
      recall1.value = "";
      recall2.value = "";
      recall3.value = "";
    };
    saveSettingsBtn.onclick = saveSettings;
    exportTextBtn.onclick = exportSummary;

    // ---------- Init ----------
    updateModeUI();
    renderHistory();
    startTest();
    drawClock();
  </script>
</body>
</html>
